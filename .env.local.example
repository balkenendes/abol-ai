# ============================================================
# PIPELOOP.AI — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- SUPABASE (database + auth) ---
# From: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ANTHROPIC (AI engine) ---
# From: https://console.anthropic.com → API Keys
# You already have $29 credit ✅
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- STRIPE (payments) ---
# From: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# From: Stripe → Products (after creating the 3 plans)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# --- RESEND (email) ---
# From: https://resend.com → API Keys
RESEND_API_KEY=re_...

# --- UPSTASH REDIS (message bus between agents) ---
# From: https://console.upstash.com → Create database → REST API
UPSTASH_REDIS_URL=https://...upstash.io
UPSTASH_REDIS_TOKEN=AX...

# --- PHANTOMBUSTER (LinkedIn automation) ---
# From: https://phantombuster.com → Settings → API
PHANTOMBUSTER_API_KEY=...
# Phantom IDs from your PhantomBuster dashboard (after setting up the agents)
PHANTOM_CONNECT_ID=...
PHANTOM_DM_ID=...

# --- APOLLO.IO (lead sourcing) ---
# From: https://app.apollo.io → Settings → Integrations → API
APOLLO_API_KEY=...

# --- JINA.AI (website scraping — optional, improves enrichment quality) ---
# From: https://jina.ai → API
JINA_API_KEY=...

# --- PIPEDRIVE (CRM sync — optional) ---
# From: Pipedrive → Settings → Integrations → API keys
PIPEDRIVE_API_KEY=...

# --- SECURITY ---
# Generate a random secret: open terminal and run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_random_32_char_secret_here
CRON_SECRET=your_random_32_char_secret_here

# --- APP ---
NEXT_PUBLIC_APP_URL=https://app.pipeloop.ai
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/sam-balkenende/30min
